{
  "expo": {
    "name": "App Chef",
    "slug": "app-chef",
    "scheme": "appchef",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#4A2C2A"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.appchef.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#4A2C2A"
      },
      "package": "com.appchef.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "INTERNET"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyB9X-ML0-qrdfZbDqUtrMsy927PmBQFV8g"
        }
      }
    },
    "web": {
      "favicon": "./assets/icon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "App Chef necesita tu ubicación para mostrar cenas y personas cercanas."
        }
      ]
    ]
  }
}
